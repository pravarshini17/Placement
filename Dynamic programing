//Dynamic Programing(Fibonocci series)
public class FibonocciDP {
    public static void main(String[] args) {
        int n = 10; 
        int[] dp = new int[n];
        dp[0] = 0;
        dp[1] = 1;
        System.out.print("First " + n + " Fibonacci numbers: ");
        System.out.print(dp[0] + " ");
        System.out.print(dp[1] + " ");
        for (int i = 2; i < n; i++) {
            dp[i] = dp[i - 1] + dp[i - 2];
            System.out.print(dp[i] + " ");
        }
    }
}
